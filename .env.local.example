# Absolute path to your curriculum folder.
# The app reads *.md module files and mcq/<moduleId>.json pools from here (read-only).
# It also reads and writes _llmtutor-state.json in this same folder (the progress sidecar).
# Example: /Users/yourname/my-curriculum  or  /home/yourname/learning/llm-curriculum
CURRICULUM_DIR=/absolute/path/to/your/curriculum
